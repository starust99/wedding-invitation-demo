NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ASSET_BUCKET=wedding-assets
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-session-secret

# Optional Cloudinary uploads. Prefer CLOUDINARY_URL or set the three values below.
CLOUDINARY_URL=cloudinary://api-key:api-secret@cloud-name
CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=api-key
CLOUDINARY_API_SECRET=api-secret
CLOUDINARY_UPLOAD_FOLDER=wedding-invitation-demo
CLOUDINARY_MAX_ASSET_MB=80
